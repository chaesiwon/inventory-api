# ═══════════════════════════════════════════
# 백엔드 환경변수 (.env.example)
# Render / Railway에서 환경변수로 설정
# ═══════════════════════════════════════════

# 세션 암호화 키 (랜덤 문자열 32자 이상)
SECRET_KEY=your-super-secret-key-change-this-in-production-32chars

# 프론트엔드 URL (Vercel 배포 후 실제 URL)
# 여러 도메인은 쉼표로 구분
FRONTEND_URL=https://your-inventory-app.vercel.app,https://your-custom-domain.com

# 포트 (Render/Railway가 자동 주입 - 수정 불필요)
PORT=8000
